<!DOCTYPE html>
<html lang="de">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <meta name="description" content="<%= description %>">
  <meta name="author" content="<%= company.name %>">
  <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1">
  
  <!-- AI SEO / GEO (Generative Engine Optimization) Meta Tags -->
  <meta name="classification" content="Gebäudereinigung, Unterhaltsreinigung, Industriereinigung, Produktionsunterstützung">
  <meta name="coverage" content="Deutschland, Baden-Württemberg, Singen, Konstanz, Radolfzell, Süddeutschland">
  <meta name="business-entity" content="GoldClean (HRB 726019 Freiburg)">
  <meta name="business-type" content="Corporate Cleaning Company, Reinigungsunternehmen">
  
  <!-- Open Graph / Facebook -->
  <meta property="og:title" content="<%= title %>">
  <meta property="og:description" content="<%= description %>">
  <meta property="og:type" content="website">
  <meta property="og:url" content="<%= company.website %>/<%- typeof path !== 'undefined' ? path : '' %>">
  <meta property="og:image" content="<%= company.website %>/images/logo.webp">
  
  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= title %>">
  <meta name="twitter:description" content="<%= description %>">
  <meta name="twitter:image" content="<%= company.website %>/images/logo.webp">
  
  <link rel="icon" type="image/png" href="images/favicon.png">
  <link rel="canonical" href="<%= company.website %>/<%- typeof path !== 'undefined' ? path : '' %>">
  
  <link rel="stylesheet" href="css/styles.css">
  
  <%- include('partials/schema', { schema: typeof schema !== 'undefined' ? schema : null }) %>
</head>

<body>
  <div id="root">
    <div class="min-h-screen flex flex-col">
      <%- include('partials/header') %>
      <main class="flex-grow pt-20 md:pt-28">
        <%- body %>
      </main>
      <%- include('partials/footer') %>
    </div>
  </div>
  <%- include('partials/mobile-menu') %>
  <script src="js/main.js"></script>
</body>

</html>