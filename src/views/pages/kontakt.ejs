---
title: "Kontakt - GoldClean"
description: "Kontaktieren Sie GoldClean - Wir freuen uns auf Ihre Anfrage für professionelle Reinigungsdienstleistungen in Süddeutschland."
---
<section class="hero-section min-h-[400px] md:min-h-[500px]"
  style="background-image: url(&quot;/images/technische-reinigung.webp&quot;);">
  <div class="hero-overlay"></div>
  <div class="container-custom relative z-10 text-white py-16">
    <div class="max-w-3xl">
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold mb-4 leading-tight">Was können wir für Sie tun?</h1>
      <p class="text-lg md:text-xl opacity-90 mb-8 max-w-2xl">Bei Fragen oder sonstigen Anliegen sind wir gerne
        für Sie da. Sie können uns jederzeit anrufen, eine Mail schreiben oder per Kontaktformular kontaktieren.
        In einem persönlichen Termin finden wir gemeinsam eine passende Lösung für Ihre Anforderungen und
        Bedürfnisse.</p>
    </div>
  </div>
</section>
<section class="section-padding">
  <div class="container-custom">
    <div class="grid lg:grid-cols-3 gap-12">
      <div class="space-y-8">
        <div class="hidden"></div>
        <div>
          <h4 class="font-semibold text-primary mb-2 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-phone h-5 w-5">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
            </svg>
            Telefon
          </h4>
          <a href="tel:<%= company.phone.replace(/\s+/g, '') %>" class="text-muted-foreground hover:text-primary transition-colors"><%= company.phone %></a>
        </div>
        <div>
          <h4 class="font-semibold text-primary mb-2 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-mail h-5 w-5">
              <rect width="20" height="16" x="2" y="4" rx="2"></rect>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
            </svg>
            E-Mail
          </h4>
          <a href="mailto:<%= company.email %>" class="text-muted-foreground hover:text-primary transition-colors"><%= company.email %></a>
        </div>
        <div>
          <h4 class="font-semibold text-primary mb-2 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-map-pin h-5 w-5">
              <path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"></path>
              <circle cx="12" cy="10" r="3"></circle>
            </svg>
            Anschrift
          </h4>
          <p class="text-muted-foreground">
            <%= company.name %><br>
            <%= company.address.street %><br>
            <%= company.address.zip %> <%= company.address.city %><br>
            <%= company.address.country %>
          </p>
        </div>
        <div>
          <h4 class="font-semibold text-primary mb-2 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-clock h-5 w-5">
              <circle cx="12" cy="12" r="10"></circle>
              <polyline points="12 6 12 12 16 14"></polyline>
            </svg>
            Bürozeiten
          </h4>
          <div class="text-sm text-muted-foreground space-y-1">
            <div class="flex justify-between max-w-xs"><span>Montag</span><span>8:00 – 17:00 Uhr</span></div>
            <div class="flex justify-between max-w-xs"><span>Dienstag</span><span>8:00 – 17:00 Uhr</span></div>
            <div class="flex justify-between max-w-xs"><span>Mittwoch</span><span>8:00 – 17:00 Uhr</span></div>
            <div class="flex justify-between max-w-xs"><span>Donnerstag</span><span>8:00 – 17:00 Uhr</span></div>
            <div class="flex justify-between max-w-xs"><span>Freitag</span><span>8:00 – 17:00 Uhr</span></div>
          </div>
        </div>
      </div>
      <div class="lg:col-span-2">
        <h2 class="text-2xl md:text-3xl font-bold mb-6">Wir freuen uns auf Ihre Anfrage</h2>
        
        <!-- Form integrated with Web3Forms static form handler -->
        <form action="https://api.web3forms.com/submit" method="POST" class="space-y-6">
          <input type="hidden" name="access_key" value="YOUR_ACCESS_KEY_HERE">
          <input type="hidden" name="subject" value="Neue Anfrage über GoldClean Website">
          <input type="hidden" name="from_name" value="<%= company.name %> Website">
          <input type="checkbox" name="botcheck" class="hidden" style="display: none;">

          <div class="grid md:grid-cols-2 gap-6">
            <div>
              <input type="text" name="name" placeholder="Ihr Name *" required=""
                class="w-full px-4 py-3 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
            </div>
            <div>
              <input type="email" name="email" placeholder="Ihre E-Mail-Adresse *" required=""
                class="w-full px-4 py-3 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
            </div>
          </div>
          <div class="grid md:grid-cols-2 gap-6">
            <div>
              <input type="tel" name="phone" placeholder="Ihre Telefonnummer"
                class="w-full px-4 py-3 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
            </div>
            <div>
              <select name="service"
                class="w-full px-4 py-3 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                <option value="">– Bitte auswählen –</option>
                <% company.services.forEach(function(service) { %>
                  <option value="<%= service.id %>"><%= service.name %></option>
                <% }); %>
                <option value="beratung">Beraten Sie mich</option>
              </select>
            </div>
          </div>
          <div>
            <textarea name="message" placeholder="Ihre Nachricht" rows="6" required=""
              class="w-full px-4 py-3 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent resize-none"></textarea>
          </div>
          <p class="text-sm text-muted-foreground">* Pflichtfelder<br>Sämtliche Daten werden gemäß
            Datenschutzerklärung nur streng zweckgebunden zur Bearbeitung und Beantwortung Ihrer Anfrage
            benutzt.</p>
          <div class="flex items-start gap-3">
            <input type="checkbox" id="privacy" required="" class="mt-1">
            <label for="privacy" class="text-sm text-muted-foreground">
              Ich habe die <a href="datenschutz.html" class="text-primary hover:underline">Datenschutzerklärung</a> zur Kenntnis genommen und bin damit einverstanden, dass die von mir angegebenen Daten elektronisch erhoben und gespeichert werden. *
            </label>
          </div>
          <button type="submit" class="btn-primary">Nachricht senden</button>
        </form>
      </div>
    </div>
  </div>
</section>
<!-- Interactive OpenStreetMap instead of placeholder (GDPR compliant and free) -->
<section class="h-96 w-full relative">
  <iframe 
    class="w-full h-full border-0" 
    src="https://www.openstreetmap.org/export/embed.html?bbox=8.8185%2C47.7492%2C8.8585%2C47.7692&amp;layer=mapnik&amp;marker=47.7592%2C8.8385" 
    allowfullscreen="" 
    loading="lazy">
  </iframe>
</section>